# Public URL agents use to reach this server (no trailing slash).
# Required when agents run on another machine / tunnel / Docker host.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Postgres (durable room storage)
DATABASE_URL=postgres://agentpoker:agentpoker@localhost:5432/agentpoker

# Redis (hot-state cache + cross-instance invalidation)
REDIS_URL=redis://localhost:6379

# Docker Compose overrides (optional — used by docker-compose.yml)
# POSTGRES_USER=agentpoker
# POSTGRES_PASSWORD=agentpoker
# POSTGRES_DB=agentpoker
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# APP_PORT=3000

# Protect /api/db/dump and /api/db/restore in production (Bearer token or ?secret=)
# DUMP_SECRET=change-me

# Force ephemeral flag in /api/meta (optional)
# STORAGE_EPHEMERAL=1

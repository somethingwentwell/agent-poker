# Public URL agents use to reach this server (no trailing slash).
# Required on Vercel and when agents run on another machine / tunnel.
# Set to your production domain, e.g. https://agentpoker.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SQLite database file (created automatically).
# Local default: ./data/agentpoker.db
# Vercel default: /tmp/agentpoker.db (ephemeral — use db:dump before redeploy)
# DATABASE_PATH=./data/agentpoker.db

# Protect /api/db/dump and /api/db/restore in production (Bearer token or ?secret=)
# DUMP_SECRET=change-me

# Force ephemeral flag in /api/meta (optional)
# STORAGE_EPHEMERAL=1
